# Vigil — Environment Variables
# Copy this file to .env and fill in your values.
# All variables have safe defaults (scripts degrade gracefully when unset).

# ─── Weather ─────────────────────────────────────────────────────────────
WEATHER_LAT=35.2271          # Latitude  (default: Charlotte, NC)
WEATHER_LON=-80.8431         # Longitude
WEATHER_TZ=America/New_York  # IANA timezone
VIGIL_TIMEZONE=America/New_York  # Local date boundary for briefs/tasks/birthdays

# ─── SnapTrade (brokerage positions) ─────────────────────────────────────
SNAPTRADE_CONSUMER_KEY=
SNAPTRADE_CLIENT_ID=
SNAPTRADE_USER_ID=
SNAPTRADE_USER_SECRET=

# JSON map: SnapTrade account name → portfolio category (Roth/Traditional/HSA)
# Example: {"PCRA - ROTH": "Roth", "PCRA - TRAD": "Traditional"}
ACCOUNT_MAP={}

# ─── OFX Direct Connect (bank transactions) ──────────────────────────────
# JSON array of banks, each with url, org, fid, user, pass, accounts.
# Example: [{"name":"BankA","url":"...","org":"...","fid":"...","user":"...","pass":"...","accounts":[{"id":"123","type":"CHECKING"}]}]
OFX_BANKS_CONFIG=[]

# ─── FRED API (recession indicators) ─────────────────────────────────────
# Free key from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ─── Bank red-flag thresholds ────────────────────────────────────────────
LOOKBACK_DAYS=7                   # Days of transactions to scan
LARGE_TRANSACTION_THRESHOLD=500   # Dollar threshold for "large transaction" alerts
LOW_BALANCE_THRESHOLD=1000        # Dollar threshold for "low balance" alerts
KNOWN_VENDORS=                    # Pipe-separated vendor names to suppress alerts

# ─── Data Directory ──────────────────────────────────────────────────────
# Root directory for all data files. Sub-paths (reading plan, books,
# contacts, checklist) derive from this unless individually overridden.
VIGIL_DATA_DIR=data

# Private runtime handoff/cache files for Phase 2.
# Default: $XDG_RUNTIME_DIR/vigil if available, else $VIGIL_DATA_DIR/runtime
# VIGIL_RUNTIME_DIR=

# ─── Bible Reading ───────────────────────────────────────────────────────
# Defaults: $VIGIL_DATA_DIR/reading_plan.json, $VIGIL_DATA_DIR/books
# READING_PLAN_PATH=
# BOOKS_DIR=

# ─── Financial Checklist ─────────────────────────────────────────────────
# Default: $VIGIL_DATA_DIR/financial_checklist.md
# CHECKLIST_PATH=

# ─── OFX statement files (manual downloads, e.g. Chase credit cards) ─────
# Directory containing .qfx/.ofx files; parsed files move to processed/ subfolder
OFX_STATEMENTS_DIR=

# Max recent transactions to include in output (trims for LLM token budget)
MAX_RECENT_TRANSACTIONS=10

# ─── Anytype API (daily brief writer) ────────────────────────────────────
# Generated via: anytype auth apikey create
ANYTYPE_API_KEY=
ANYTYPE_SPACE_ID=

# ─── Todoist (read-only task list for daily brief) ───────────────────────
TODOIST_API_TOKEN=

# ─── Birthdays ───────────────────────────────────────────────────────────
# Default: $VIGIL_DATA_DIR/contacts.json
# CONTACTS_PATH=
BIRTHDAY_USE_LLM=false          # Set to "true" to use LLM for birthday messages
OPENROUTER_API_KEY=             # Required only if BIRTHDAY_USE_LLM=true
